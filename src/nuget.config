<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Repo-scoped NuGet configuration. All solution packages come from nuget.org.
    `clear` ignores any inherited/global sources so builds are identical on every machine
    and in CI. Central Package Management (Directory.Packages.props) requires either a single
    source or source mapping; we use a single mapped source here.
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>

  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
